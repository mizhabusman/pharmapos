# Copy to backend/.env and fill in real values. Never commit backend/.env.

# Google Gemini API key — required for prescription OCR extraction.
GEMINI_API_KEY=your_api_key_here

# Deployment environment: "development" (default) or "production". In
# production the server REFUSES to start unless AUTH_PASSWORD is set and
# AUTH_SECRET_KEY is changed from its insecure default.
ENVIRONMENT=development

# --- Authentication (required for login to work) ---
# Shared login password/PIN the pharmacist enters.
AUTH_PASSWORD=change-me
# Secret used to sign login tokens. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET_KEY=change-me-to-a-long-random-string
# AUTH_TOKEN_EXPIRE_MINUTES=720   # how long a login stays valid (default 12h)

# --- Login rate limiting (brute-force throttle) ---
# After LOGIN_MAX_ATTEMPTS failures from one IP within LOGIN_WINDOW_SECONDS,
# that IP is blocked for LOGIN_BLOCK_SECONDS. Defaults shown.
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_WINDOW_SECONDS=300
# LOGIN_BLOCK_SECONDS=300

# --- Optional overrides (defaults shown) ---
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_INPUT_PRICE_PER_1M=0.075
# GEMINI_OUTPUT_PRICE_PER_1M=0.30
# INR_CONVERSION_RATE=83.5
# CORS_ORIGINS=http://localhost:5173
